{
  "name": "opencode-gem-team",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "OpenCode Gem Team plugin scaffold.",
  "main": "./dist/src/index.js",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    },
    "./server": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    }
  },
  "scripts": {
    "compile": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run compile && node --test \"dist/test/**/*.test.js\"",
    "lint": "npm run typecheck && npm run validate:package-scripts",
    "sync:agents": "node scripts/sync-agents.mjs",
    "validate:sync": "node scripts/validate-sync.mjs",
    "validate:dist": "node scripts/validate-dist.mjs",
    "validate:package-scripts": "node scripts/validate-package-scripts.mjs",
    "validate:no-model-ids": "node scripts/validate-no-model-ids.mjs"
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.15.13"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "typescript": "^5.9.3"
  }
}
